# otibo.dev 環境変数テンプレート
# 実値はこのファイルに書かない。Cloudflare Pages の Environment Variables で設定する。
# NF-003: 個人情報の実値(本名・住所・電話番号)はリポジトリに書き込まない。

# 特商法表記の事業者情報(tokushoho ページ + medo/privacy ページで使用)
OWNER_NAME=
OWNER_ADDRESS=
OWNER_PHONE=

# 法的文書の施行日(medo/privacy, medo/terms で使用)
# 形式例: 2026年XX月XX日
# 未設定時は「本ポリシー/本規約は Medo のストア公開日をもって発効します」という文言に自動フォールバック
EFFECTIVE_DATE=
